{
  "name": "demo-video-gen-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core/tsconfig.json packages/source/tsconfig.json packages/ai/tsconfig.json packages/playwright/tsconfig.json packages/voicevox/tsconfig.json packages/renderer/tsconfig.json packages/cli/tsconfig.json",
    "build:watch": "tsc -b --watch packages/*/tsconfig.json",
    "dev": "pnpm run build && tsx packages/cli/src/index.ts",
    "clean": "find packages -name 'dist' -type d -exec rm -rf {} + ; find packages -name '*.tsbuildinfo' -delete",
    "lint": "eslint packages/*/src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "task install",
    "setup:full": "task install PROFILE=local WITH_OLLAMA=true",
    "setup:cloud-only": "task install PROFILE=local WITH_OLLAMA=false",
    "setup:ci": "task install PROFILE=ci WITH_OLLAMA=true",
    "serve": "task serve",
    "serve:stop": "task stop",
    "doctor": "task doctor",
    "task": "task"
  },
  "devDependencies": {
    "@go-task/cli": "^3.52.0",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^9.39.5",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
