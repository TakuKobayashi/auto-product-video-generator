{
  "name": "demo-video-gen-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core/tsconfig.json packages/ai/tsconfig.json packages/playwright/tsconfig.json packages/voicevox/tsconfig.json packages/renderer/tsconfig.json packages/cli/tsconfig.json",
    "build:watch": "tsc -b --watch packages/*/tsconfig.json",
    "dev": "tsx packages/cli/src/index.ts",
    "clean": "find packages -name 'dist' -type d | xargs rm -rf",
    "lint": "eslint packages/*/src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node scripts/install.mjs",
    "setup:full": "node scripts/install.mjs --profile=local --with-ollama=true",
    "setup:cloud-only": "node scripts/install.mjs --profile=local --with-ollama=false",
    "setup:ci": "node scripts/install.mjs --profile=ci --with-ollama=true",
    "serve": "node scripts/serve.mjs",
    "serve:stop": "node scripts/stop.mjs",
    "doctor": "node scripts/doctor.mjs",
    "task": "task"
  },
  "devDependencies": {
    "@go-task/cli": "^3.44.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "playwright": "^1.47.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
