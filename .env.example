# Copy this file to .env and fill in the values you need.
# .env is loaded automatically by Taskfile.yml (dotenv) and by Node's
# `--env-file` is NOT required — the CLI reads process.env directly.

# Required only if llm.provider (or llm.fallbackProvider) is "gemini".
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Ollama daemon URL (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Optional: override the ffmpeg/ffprobe binaries instead of the bundled ones
# FFMPEG_PATH=
# FFPROBE_PATH=
